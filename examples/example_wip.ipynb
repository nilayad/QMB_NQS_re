 "source": [
 "# Cell 1: Imports\n",
 "import sys\n",
 "import os\n",
 "sys.path.insert(0, os.path.abspath('..'))\n",
 "\n",
 "import numpy as np\n",
 "import scipy.linalg\n",
 "import tensorflow as tf\n",
 "import matplotlib.pyplot as plt\n",
 "\n",
 "dtype_float = tf.float64\n",
 "dtype_comp = tf.complex128\n",
 "tf.keras.backend.set_floatx('float64')\n",
 "\n",
 "from nqs.models import RBM\n",
 "from nqs.operators import TransverseFieldIsing, config_to_spins, spins_to_config\n",
 "from nqs.sampling import MetropolisSampler\n",
 "from nqs.training import VMCTrainer\n",
 "from nqs.stochastic_reconfiguration import StochasticReconfiguration\n",
 "\n",
 "print('Imports OK')"
 ]
 },
 {
 "cell_type": "code",
 "execution_count": null,
 "metadata": {},
 "outputs": [],
 "source": [
 "# Cell 2: System parameters\n",
 "L = 8\n",
 "J = 1.0\n",
 "g = 1.0   # transverse field (h)\n",
 "pbc = True\n",
 "\n",
 "print(f'System: L={L}, J={J}, g={g}, pbc={pbc}')"
 ]
 },
 {
 "cell_type": "code",
 "execution_count": null,
 "metadata": {},
 "outputs": [],
 "source": [
 "# Cell 3: Exact diagonalization ground state\n",
 "# Build the full TFIM Hamiltonian matrix and diagonalise with scipy.\n",
 "# Only feasible for small L (<=14). L=8 is fine.\n",
 "\n",
 "def build_tfim_matrix(L, J, h, pbc):\n",
 "    \"\"\"Build full 2^L x 2^L TFIM Hamiltonian matrix.\"\"\"\n",
 "    N = 2 ** L\n",
 "    H = np.zeros((N, N), dtype=np.float64)\n",
 "    for s in range(N):\n",
 "        # ZZ coupling terms\n",
 "        for i in range(L - (0 if pbc else 1)):\n",
 "            j = (i + 1) % L\n",
 "            si = 1 - 2 * ((s >> i) & 1)\n",
 "            sj = 1 - 2 * ((s >> j) & 1)\n",
 "            H[s, s] -= J * si * sj\n",
 "        # Transverse field (X) terms\n",
 "        for i in range(L):\n",
 "            s2 = s ^ (1 << i)\n",
 "            H[s, s2] -= h\n",
 "    return H\n",
 "\n",
 "H_mat = build_tfim_matrix(L, J, g, pbc)\n",
 "evals, evecs = scipy.linalg.eigh(H_mat)\n",
 "E0_ed = evals[0]\n",
 "psi0_ed = evecs[:, 0]\n",
 "\n",
 "print(f'ED ground state energy:         E0   = {E0_ed:.8f}')\n",
 "print(f'ED ground state energy per site: E0/L = {E0_ed/L:.8f}')"
 ]
 },
 {
 "cell_type": "code",
 "execution_count": null,
 "metadata": {},
 "outputs": [],
 "source": [
 "# Cell 4: Build RBM model\n",
 "alpha = 2   # hidden-unit ratio\n",
 "model = RBM(num_sites=L, num_hidden=alpha * L)\n",
 "\n",
 "# Build weights by running a dummy forward pass\n",
 "dummy = tf.ones((1, L), dtype=tf.float64)\n",
 "_ = model(dummy)\n",
 "\n",
 "print(f'RBM model: {L} visible, {alpha*L} hidden units')\n",
 "print(f'Total trainable parameters: {model.count_params()}')"
 ]
 },
 {
 "cell_type": "code",
 "execution_count": null,
 "metadata": {},
 "outputs": [],
 "source": [
 "# Cell 5: VMC ground-state training\n",
 "n_samples = 500\n",
 "n_epochs  = 500\n",
 "lr        = 0.01\n",
 "\n",
 "hamiltonian = TransverseFieldIsing(num_sites=L, J=J, h=g, pbc=pbc)\n",
 "\n",
 "sampler = MetropolisSampler(\n",
 "    num_sites=L,\n",
 "    num_samples=n_samples,\n",
 "    num_chains=1,\n",
 "    warmup_steps=200\n",
 ")\n",
 "\n",
 "trainer = VMCTrainer(\n",
 "    model=model,\n",
 "    hamiltonian=hamiltonian,\n",
 "    sampler=sampler,\n",
 "    learning_rate=lr\n",
 ")\n",
 "\n",
 "print('Starting VMC training...')\n",
 "history = trainer.train(num_steps=n_epochs)\n",
 "energies = history['energy']\n",
 "\n",
 "print(f'\nFinal VMC energy: {energies[-1]:.6f}')\n",
 "print(f'ED  ground state: {E0_ed:.6f}')\n",
 "print(f'Error:            {abs(energies[-1] - E0_ed):.6f}')"
 ]
 },
 {
 "cell_type": "code",
 "execution_count": null,
 "metadata": {},
 "outputs": [],
 "source": [
 "# Cell 6: SR optimisation\n",
 "model_sr = RBM(num_sites=L, num_hidden=alpha * L)\n",
 "_ = model_sr(dummy)   # build weights\n",
 "\n",
 "sampler_sr = MetropolisSampler(\n",
 "    num_sites=L,\n",
 "    num_samples=n_samples,\n",
 "    num_chains=1,\n",
 "    warmup_steps=200\n",
 ")\n",
 "\n",
 "sr_trainer = StochasticReconfiguration(\n",
 "    model=model_sr,\n",
 "    hamiltonian=hamiltonian,\n",
 "    sampler=sampler_sr,\n",
 "    learning_rate=lr,\n",
 "    diagonal_shift=0.01\n",
 ")\n",
 "\n",
 "print('Starting SR training...')\n",
 "history_sr = sr_trainer.train(num_steps=n_epochs)\n",
 "energies_sr = history_sr['energy']\n",
 "\n",
 "print(f'\nFinal SR energy:  {energies_sr[-1]:.6f}')\n",
 "print(f'ED  ground state: {E0_ed:.6f}')\n",
 "print(f'Error:            {abs(energies_sr[-1] - E0_ed):.6f}')"
 ]
 },
 {
 "cell_type": "code",
 "execution_count": null,
 "metadata": {},
 "outputs": [],
 "source": [
 "# Cell 7: Final energy evaluation with error bar\n",
 "eval_sampler = MetropolisSampler(\n",
 "    num_sites=L,\n",
 "    num_samples=2000,\n",
 "    num_chains=1,\n",
 "    warmup_steps=200\n",
 ")\n",
 "\n",
 "samples_eval, _ = eval_sampler.sample(\n",
 "    model=lambda s: model_sr(s, training=False),\n",
 "    show_progress=False\n",
 ")\n",
 "\n",
 "# Compute local energies\n",
 "def log_psi_func(configs):\n",
 "    return model_sr(configs, training=False)\n",
 "\n",
 "configs_int = np.array([spins_to_config(s) for s in samples_eval])\n",
 "e_loc = hamiltonian.local_energy(configs_int, log_psi_func)\n",
 "\n",
 "e_mean = float(np.mean(e_loc))\n",
 "e_err  = float(np.std(e_loc) / np.sqrt(len(e_loc)))\n",
 "\n",
 "print(f'Final energy estimate: E = {e_mean:.6f} +/- {e_err:.6f}')\n",
 "print(f'ED  ground state:      E = {E0_ed:.6f}')"
 ]
 },
 {
 "cell_type": "code",
 "execution_count": null,
 "metadata": {},
 "outputs": [],
 "source": [
 "# Cell 8: Plot energy convergence\n",
 "plt.figure(figsize=(10, 5))\n",
 "plt.plot(energies,    label='VMC (SGD)')\n",
 "plt.plot(energies_sr, label='VMC (SR)')\n",
 "plt.axhline(E0_ed, color='k', linestyle='--', label='ED (exact)')\n",
 "plt.xlabel('Epoch')\n",
 "plt.ylabel('Energy')\n",
 "plt.title(f'TFIM Ground State Training  L={L}, g={g}')\n",
 "plt.legend()\n",
 "plt.tight_layout()\n",
 "plt.show()"
 ]
 },
 {
 "cell_type": "code",
 "execution_count": null,
 "metadata": {},
