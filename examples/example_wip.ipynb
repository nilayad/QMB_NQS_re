{\n "cells": [\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": [\n    "# Cell 1: Imports\n",\n    "import sys\n",\n    "import os\n",\n    "sys.path.insert(0, os.path.abspath('..'))\n",\n    "\n",\n    "import numpy as np\n",\n    "import scipy.linalg\n",\n    "import tensorflow as tf\n",\n    "import matplotlib.pyplot as plt\n",\n    "\n",\n    "dtype_float = tf.float64\n",\n    "dtype_comp = tf.complex128\n",\n    "tf.keras.backend.set_floatx('float64')\n",\n    "\n",\n    "from nqs.models import RBM\n",\n    "from nqs.operators import TransverseFieldIsing, config_to_spins, spins_to_config\n",\n    "from nqs.sampling import MetropolisSampler\n",\n    "from nqs.training import VMCTrainer\n",\n    "from nqs.stochastic_reconfiguration import StochasticReconfiguration\n",\n    "\n",\n    "print('Imports OK')"\n   ]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": [\n    "# Cell 2: System parameters\n",\n    "L = 8\n",\n    "J = 1.0\n",\n    "g = 1.0   # transverse field (h)\n",\n    "pbc = True\n",\n    "\n",\n    "print(f'System: L={L}, J={J}, g={g}, pbc={pbc}')"\n   ]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": [\n    "# Cell 3: Exact diagonalization ground state\n",\n    "# Build the full TFIM Hamiltonian matrix and diagonalise with scipy.\n",\n    "# Only feasible for small L (<=14). L=8 is fine.\n",\n    "\n",\n    "def build_tfim_matrix(L, J, h, pbc):\n",\n    "    \"\"\"Build full 2^L x 2^L TFIM Hamiltonian matrix.\"\"\"\n",\n    "    N = 2 ** L\n",\n    "    H = np.zeros((N, N), dtype=np.float64)\n",\n    "    for s in range(N):\n",\n    "        # ZZ coupling terms\n",\n    "        for i in range(L - (0 if pbc else 1)):\n",\n    "            j = (i + 1) % L\n",\n    "            si = 1 - 2 * ((s >> i) & 1)\n",\n    "            sj = 1 - 2 * ((s >> j) & 1)\n",\n    "            H[s, s] -= J * si * sj\n",\n    "        # Transverse field (X) terms\n",\n    "        for i in range(L):\n",\n    "            s2 = s ^ (1 << i)\n",\n    "            H[s, s2] -= h\n",\n    "    return H\n",\n    "\n",\n    "H_mat = build_tfim_matrix(L, J, g, pbc)\n",\n    "evals, evecs = scipy.linalg.eigh(H_mat)\n",\n    "E0_ed = evals[0]\n",\n    "psi0_ed = evecs[:, 0]\n",\n    "\n",\n    "print(f'ED ground state energy:         E0   = {E0_ed:.8f}')\n",\n    "print(f'ED ground state energy per site: E0/L = {E0_ed/L:.8f}')"\n   ]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": [\n    "# Cell 4: Build RBM model\n",\n    "alpha = 2   # hidden-unit ratio\n",\n    "model = RBM(num_sites=L, num_hidden=alpha * L)\n",\n    "\n",\n    "# Build weights by running a dummy forward pass\n",\n    "dummy = tf.ones((1, L), dtype=tf.float64)\n",\n    "_ = model(dummy)\n",\n    "\n",\n    "print(f'RBM model: {L} visible, {alpha*L} hidden units')\n",\n    "print(f'Total trainable parameters: {model.count_params()}')"\n   ]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": [\n    "# Cell 5: VMC ground-state training\n",\n    "n_samples = 500\n",\n    "n_epochs  = 500\n",\n    "lr        = 0.01\n",\n    "\n",\n    "hamiltonian = TransverseFieldIsing(num_sites=L, J=J, h=g, pbc=pbc)\n",\n    "\n",\n    "sampler = MetropolisSampler(\n",\n    "    num_sites=L,\n",\n    "    num_samples=n_samples,\n",\n    "    num_chains=1,\n",\n    "    warmup_steps=200\n",\n    ")\n",\n    "\n",\n    "trainer = VMCTrainer(\n",\n    "    model=model,\n",\n    "    hamiltonian=hamiltonian,\n",\n    "    sampler=sampler,\n",\n    "    learning_rate=lr\n",\n    ")\n",\n    "\n",\n    "print('Starting VMC training...')\n",\n    "history = trainer.train(num_steps=n_epochs)\n",\n    "energies = history['energy']\n",\n    "\n",\n    "print(f'Final VMC energy: {energies[-1]:.6f}')\n",\n    "print(f'ED  ground state: {E0_ed:.6f}')\n",\n    "print(f'Error:            {abs(energies[-1] - E0_ed):.6f}')"\n   ]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": [\n    "# Cell 6: SR optimisation\n",\n    "model_sr = RBM(num_sites=L, num_hidden=alpha * L)\n",\n    "_ = model_sr(dummy)   # build weights\n",\n    "\n",\n    "sampler_sr = MetropolisSampler(\n",\n    "    num_sites=L,\n",\n    "    num_samples=n_samples,\n",\n    "    num_chains=1,\n",\n    "    warmup_steps=200\n",\n    ")\n",\n    "\n",\n    "sr_trainer = StochasticReconfiguration(\n",\n    "    model=model_sr,\n",\n    "    hamiltonian=hamiltonian,\n",\n    "    sampler=sampler_sr,\n",\n    "    learning_rate=lr,\n",\n    "    diagonal_shift=0.01\n",\n    ")\n",\n    "\n",\n    "print('Starting SR training...')\n",\n    "history_sr = sr_trainer.train(num_steps=n_epochs)\n",\n    "energies_sr = history_sr['energy']\n",\n    "\n",\n    "print(f'Final SR energy:  {energies_sr[-1]:.6f}')\n",\n    "print(f'ED  ground state: {E0_ed:.6f}')\n",\n    "print(f'Error:            {abs(energies_sr[-1] - E0_ed):.6f}')"\n   ]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": [\n    "# Cell 7: Final energy evaluation with error bar\n",\n    "eval_sampler = MetropolisSampler(\n",\n    "    num_sites=L,\n",\n    "    num_samples=2000,\n",\n    "    num_chains=1,\n",\n    "    warmup_steps=200\n",\n    ")\n",\n    "\n",\n    "samples_eval, _ = eval_sampler.sample(\n",\n    "    model=lambda s: model_sr(s, training=False),\n",\n    "    show_progress=False\n",\n    ")\n",\n    "\n",\n    "# Compute local energies\n",\n    "def log_psi_func(configs):\n",\n    "    return model_sr(configs, training=False)\n",\n    "\n",\n    "configs_int = np.array([spins_to_config(s) for s in samples_eval])\n",\n    "e_loc = hamiltonian.local_energy(configs_int, log_psi_func)\n",\n    "\n",\n    "e_mean = float(np.mean(e_loc))\n",\n    "e_err  = float(np.std(e_loc) / np.sqrt(len(e_loc)))\n",\n    "\n",\n    "print(f'Final energy estimate: E = {e_mean:.6f} +/- {e_err:.6f}')\n",\n    "print(f'ED  ground state:      E = {E0_ed:.6f}')"\n   ]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": [\n    "# Cell 8: Plot energy convergence\n",\n    "plt.figure(figsize=(10, 5))\n",\n    "plt.plot(energies,    label='VMC (SGD)')\n",\n    "plt.plot(energies_sr, label='VMC (SR)')\n",\n    "plt.axhline(E0_ed, color='k', linestyle='--', label='ED (exact)')\n",\n    "plt.xlabel('Epoch')\n",\n    "plt.ylabel('Energy')\n",\n    "plt.title(f'TFIM Ground State Training  L={L}, g={g}')\n",\n    "plt.legend()\n",\n    "plt.tight_layout()\n",\n    "plt.show()"\n   ]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "metadata": {},\n   "outputs": [],\n   "source": [\n    "# Cell 9: Sampling diagnostics\n",\n    "diag_sampler = MetropolisSampler(\n",\n    "    num_sites=L,\n",\n    "    num_samples=1000,\n",\n    "    num_chains=1,\n",\n    "    warmup_steps=200\n",\n    ")\n",\n    "\n",\n    "samples, stats = diag_sampler.sample(\n",\n    "    model=lambda s: model_sr(s, training=False),\n",\n    "    show_progress=False\n",\n    ")\n",\n    "\n",\n    "samples_tf = tf.constant(samples, dtype=tf.float64)\n",\n    "print(f'Sampled {samples.shape[0]} configurations')\n",\n    "print(f\"Acceptance rate:    {stats['acceptance_rate']:.4f}\")\n",\n    "print(f'Mean magnetization: {tf.reduce_mean(samples_tf).numpy():.4f}')\n",\n    "print(f'Mean |m|:           {tf.reduce_mean(tf.abs(tf.reduce_mean(samples_tf, axis=1))).numpy():.4f}')"\n   ]\n  }\n ], \n "metadata": {\n  "kernelspec": {\n   "display_name": "Python 3",\n   "language": "python",\n   "name": "python3"\n  },\n  "language_info": {\n   "name": "python",\n   "version": "3.8.0"\n  }\n },\n "nbformat": 4,\n "nbformat_minor": 4\n}