 "source": [
 "# Cell 9: Sampling diagnostics\n",
 "diag_sampler = MetropolisSampler(\n",
 "    num_sites=L,\n",
 "    num_samples=1000,\n",
 "    num_chains=1,\n",
 "    warmup_steps=200\n",
 ")\n",
 "\n",
 "samples, stats = diag_sampler.sample(\n",
 "    model=lambda s: model_sr(s, training=False),\n",
 "    show_progress=False\n",
 ")\n",
 "\n",
 "samples_tf = tf.constant(samples, dtype=tf.float64)\n",
 "print(f'Sampled {samples.shape[0]} configurations')\n",
 "print(f'Acceptance rate:    {stats["acceptance_rate"]:.4f}')\n",
 "print(f'Mean magnetization: {tf.reduce_mean(samples_tf).numpy():.4f}')\n",
 "print(f'Mean |m|:           {tf.reduce_mean(tf.abs(tf.reduce_mean(samples_tf, axis=1))).numpy():.4f}')"
 ]
 }
